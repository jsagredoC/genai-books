# Vertex AI + Application Default Credentials (see vertex_setup.py)
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# e.g. us-west1 (Region Picker), us-central1 (many docs); must match Vertex model availability
GOOGLE_CLOUD_LOCATION=us-central1

# Optional: override default from vertex_setup.default_gemini_model_id()
# GEMINI_VERTEX_MODEL=gemini-2.5-flash

# Gemini Developer API (AI Studio) — leave unset when using Vertex; vertex_setup clears these.
# GOOGLE_API_KEY=
